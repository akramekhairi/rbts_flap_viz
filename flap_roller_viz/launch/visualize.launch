<?xml version="1.0"?>
<launch>
  <!-- Workpiece pose relative to map (origin by default).
       Roll / pitch / yaw are in DEGREES for convenience. -->
  <arg name="wkpiece_x"         default="0.0"/>
  <arg name="wkpiece_y"         default="0.0"/>
  <arg name="wkpiece_z"         default="0.0"/>
  <arg name="wkpiece_roll_deg"  default="90.0"/>
  <arg name="wkpiece_pitch_deg" default="0.0"/>
  <arg name="wkpiece_yaw_deg"   default="0.0"/>

  <!-- Encoder serial config -->
  <arg name="serial_port" default="/dev/ttyUSB0"/>
  <arg name="baud_rate" default="9600"/>
  <!-- 1 = normal direction, -1 = reversed encoder travel direction. -->
  <arg name="encoder_direction" default="-1"/>
  <arg name="launch_encoder" default="true"/>
  <arg name="launch_roller_controller" default="true"/>

  <!-- Nominal hole pitch (mm): hole_detector prefers the candidate circle whose
       spacing from the last registered hole is closest to this value.
       Post-inspection compares each gap against <expected_spacing_mm> +/- <spacing_tolerance_mm>. -->
  <arg name="expected_spacing_mm" default="25.0"/>
  <arg name="spacing_tolerance_mm" default="2.5"/>

  <!-- Event camera capture (dv_ros_capture) launched in-process so we do not
       need to run dv_ros_visualization's full launch from another terminal
       (which adds its own accumulator + GUI + RViz competing for CPU/USB).
       NOTE: source ~/dv_ws/devel/setup.bash *before* this workspace's
       setup.bash so roslaunch can find the dv_ros_capture package. Example:
         source ~/dv_ws/devel/setup.bash
         source ~/handheld_rbts_ws/devel/setup.bash (with extend flag)
         roslaunch flap_roller_viz visualize.launch
  -->
  <!-- Event camera: set enable_camera:=false (or launch_capture:=false) to skip
       capture_node — e.g. replay bags or synthetic-only testing. -->
  <arg name="enable_camera" default="true"/>
  <arg name="launch_capture" default="$(arg enable_camera)"/>
  <arg name="capture_camera_name" default=""/>
  <!-- Time slice the capture node uses to batch events before publishing (us).
       Smaller = lower latency but more ROS message overhead. 1000us = 1ms is the upstream default. -->
  <arg name="capture_time_increment_us" default="1000"/>
  <!-- Background-activity noise filter: rejects events that are not supported by
       a recent neighbor event within the given time window (us). Lower = more aggressive. -->
  <arg name="capture_noise_filter_enabled" default="true"/>
  <arg name="capture_noise_ba_time_us" default="2000"/>

  <!-- Optional live-scan bag recording. Default is OFF to keep the demo path
       light on the Surface Pro 7. No compression is used by default to avoid
       CPU spikes. -->
  <arg name="record_bag" default="false"/>
  <arg name="bag_mode" default="raw"/>
  <arg name="bag_output_dir" default="$(env HOME)/rbts_bags"/>
  <arg name="bag_prefix" default="roller"/>
  <arg name="bag_split_size_mb" default="0"/>

  <!-- Load workpiece URDF -->
  <param name="wkpiece_description" textfile="$(find Assem1)/urdf/Assem1.urdf"/>
  <node name="wkpiece_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <remap from="robot_description" to="wkpiece_description"/>
    <remap from="joint_states" to="wkpiece/joint_states"/>
  </node>

  <!-- Pre-compute radian equivalents so the args= line stays on one line
       and $(eval ...) parentheses don't confuse the substitution parser. -->
  <arg name="wkpiece_roll_rad"  default="$(eval arg('wkpiece_roll_deg')  * 3.14159265358979 / 180.0)"/>
  <arg name="wkpiece_pitch_rad" default="$(eval arg('wkpiece_pitch_deg') * 3.14159265358979 / 180.0)"/>
  <arg name="wkpiece_yaw_rad"   default="$(eval arg('wkpiece_yaw_deg')   * 3.14159265358979 / 180.0)"/>

  <!-- Static TF: map → base_link. -->
  <node name="wkpiece_static_tf" pkg="tf2_ros" type="static_transform_publisher"
        args="$(arg wkpiece_x) $(arg wkpiece_y) $(arg wkpiece_z) $(arg wkpiece_yaw_rad) $(arg wkpiece_pitch_rad) $(arg wkpiece_roll_rad) map base_link"/>

  <!-- Load roller URDF -->
  <param name="roller_description" textfile="$(find roller_handheld)/urdf/roller_handheld.urdf"/>
  <node name="roller_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <remap from="robot_description" to="roller_description"/>
  </node>

  <!-- Encoder Publisher: reads serial encoder data, publishes /tcp/vel and /roller/position -->
  <group if="$(arg launch_encoder)">
    <node name="encoder_publisher" pkg="flap_roller_viz" type="encoder_publisher.py" output="screen"
          launch-prefix="/usr/bin/python3">
      <param name="serial_port" value="$(arg serial_port)" />
      <param name="baud_rate" value="$(arg baud_rate)" />
      <param name="cylinder_diameter_m" value="0.088" />
      <param name="encoder_direction" value="$(arg encoder_direction)" />
    </node>
  </group>

  <!-- Roller Controller: encoder-driven via /roller/position -->
  <!-- start_x = 2.40 m - 1.10 m = 1.30 m -->
  <group if="$(arg launch_roller_controller)">
    <node name="roller_controller" pkg="flap_roller_viz" type="roller_controller.py" output="screen"
          launch-prefix="/usr/bin/python3">
      <param name="roller_radius" value="0.05" />
      <param name="support_radius" value="0.02" />
      <param name="start_x" value="-0.08" />
      <param name="start_y" value="0.00" />
      <param name="start_z" value="0.047" />
      <!-- Extra RPY in map frame after CAD mount (deg). Order: roll (map X), pitch (map Y), yaw (map Z). -->
      <param name="roll_extra_deg" value="-90" />
      <param name="pitch_extra_deg" value="0" />
      <param name="yaw_extra_deg" value="-90" />
      <!-- Start hidden; GUI toggle button can show it via service. -->
      <param name="markers_visible" value="false" />
    </node>
  </group>

  <!-- DV capture node: events-only, with background-activity noise filter.
       Disabling frames/imu/triggers cuts USB bandwidth and CPU substantially on
       this 2-core machine, which is the dominant source of the ~300ms image age. -->
  <group if="$(arg launch_capture)">
    <node pkg="dv_ros_capture" type="capture_node" name="capture_node" clear_params="true" output="screen">
      <param name="frames"                       value="false"/>
      <param name="events"                       value="true"/>
      <param name="imu"                          value="false"/>
      <param name="triggers"                     value="false"/>
      <param name="timeIncrement"                value="$(arg capture_time_increment_us)"/>
      <param name="noiseFiltering"               value="$(arg capture_noise_filter_enabled)"/>
      <param name="noiseBackgroundActivityTime"  value="$(arg capture_noise_ba_time_us)"/>
      <param name="cameraName"                   value="$(arg capture_camera_name)"/>
      <param name="transformImuToCameraFrame"    value="false"/>
      <param name="unbiasedImuData"              value="false"/>
    </node>
  </group>

  <!-- Motion Compensator (delayed 5s to let RViz and TF settle) -->
  <node pkg="rbts_dv_ros_accumulation" type="motion_compensator" name="motion_compensator" output="screen"
        launch-prefix="bash -c 'sleep 5; exec $0 $@'">
    <remap from="/motion_compensator/events" to="/capture_node/events" />
    <!-- Sliding-window frame generation. Each tick at `stride_ms` renders a
         frame from the last `window_size_ms` of events. stride < window
         produces overlapping (smoother) frames; stride == window disables
         sliding. -->
    <param name="window_size_ms" value="10" />
    <param name="stride_ms"      value="10" />
    <param name="contribution" value="0.45" />
    <param name="constant_depth" value="0.047" />
    <!-- Sign applied to the incoming /tcp/vel before motion compensation.
         Flip to 1.0 if the compensated image looks smeared in the wrong direction. -->
    <param name="vel_sign"       value="-1.0" />
  </node>

  <!-- Hole Detector (C++): contour-based detection on /motion_compensator/image,
       publishes /hole_markers, /motion_compensator/annotated_image, /hole_events.
       Delayed 5s like the motion compensator so the image topic is up first. -->
  <arg name="preset" default="balanced"/>
  <arg name="detector_mode" default="hough_preproc"/>
  <arg name="publish_debug_preprocessed" default="false"/>
  <arg name="publish_debug_binary" default="false"/>
  <rosparam command="load" file="$(find flap_roller_viz)/launch/presets/$(arg preset).yaml" ns="hole_detector"/>
  <node pkg="rbts_dv_ros_accumulation" type="hole_detector" name="hole_detector" output="screen"
        launch-prefix="bash -c 'sleep 5; exec $0 $@'">
    <param name="scale_mm_per_px" value="0.0422" />
    <param name="tracking_distance_threshold_mm" value="24.0" />
    <!-- Temporal persistence gate only (mm): a history sample matches a candidate
         if positions differ by less than this. Which circle wins is ranked by
         distance to expected_hole_spacing_mm (closest pitch to nominal wins). -->
    <param name="median_blur_ksize" value="5" />
    <!-- detector_mode: hough_preproc (primary), hough_raw (rollback), or contour (backup). -->
    <param name="detector_mode" value="$(arg detector_mode)" />
    <param name="publish_annotated" value="true" />
    <param name="publish_debug_preprocessed" value="$(arg publish_debug_preprocessed)" />
    <param name="publish_debug_binary" value="$(arg publish_debug_binary)" />
    <!-- Off-center correction: project each detected circle to its
         center-equivalent world position. pixel_offset_sign flips the sign
         if the correction goes the wrong way; offset_min_vel_mmps gates the
         velocity-based time shift vs scale-only fallback; history_seconds
         sizes the stamped encoder/velocity lookup buffers. -->
    <param name="pixel_offset_sign"   value="1.0" />
    <param name="offset_min_vel_mmps" value="5.0" />
    <param name="history_seconds"     value="2.0" />
    <!-- Marker placement parameters: must mirror roller_controller's start pose. -->
    <param name="roller_start_x" value="-0.14" />
    <param name="roller_start_y" value="0.00" />
    <param name="roller_start_z" value="0.0" />
    <!-- Must match unified_gui ~/expected_spacing_mm (nominal gap for tracker + analysis). -->
    <param name="expected_hole_spacing_mm" value="$(arg expected_spacing_mm)"/>
    <param name="marker_frame_id" value="map" />
  </node>

  <!-- Synthetic marker publisher: drops a known/ground-truth pattern of hole
       markers as the encoder advances past pre-sampled positions. Publishes
       on /hole_markers (distinct ns + id offset so it does not collide with
       hole_detector) and /hole_events so the unified_gui table picks it up.
       Toggle with publish_synthetic_markers:=false on the roslaunch line. -->
  <arg name="publish_synthetic_markers" default="false"/>
  <group if="$(arg publish_synthetic_markers)">
    <node pkg="rbts_dv_ros_accumulation" type="synthetic_marker_publisher.py"
          name="synthetic_marker_publisher" output="screen"
          launch-prefix="bash -c 'sleep 5; exec /usr/bin/python3 $0 $@'">
      <param name="num_holes"             value="30"/>
      <param name="start_offset_mm"       value="2.0"/>
      <param name="start_offset_tol_mm"   value="0.4"/>
      <param name="spacing_mm"            value="25.0"/>
      <param name="spacing_tol_mm"        value="0.4"/>
      <param name="diameter_mm"           value="9.70"/>
      <param name="diameter_tol_mm"       value="0.3"/>
      <param name="marker_frame_id"       value="map"/>
      <param name="roller_start_x"        value="-0.14"/>
      <param name="roller_start_y"        value="0.00"/>
      <!-- Synthetic markers sit at the workpiece top surface (map Z = 0.0). -->
      <param name="roller_start_z"        value="0.0"/>
    </node>
  </group>

  <!-- Unified GUI: embeds RViz + upscaled hole-detector image stream + scrollable
       hole list + controls + read-only detector params, all in one window.
       Replaces the previous standalone rviz and hole_detector_gui nodes.
       Delayed 1s so TF and topics are up before the embedded RViz initialises.
       Pass fullscreen:=true on the roslaunch command line for true fullscreen
       at startup (or press F11 inside the window to toggle, Esc to exit). -->
  <arg name="fullscreen" default="true"/>
  <!-- Post-inspection uses expected_spacing_mm and spacing_tolerance_mm (declared near top). -->
  <node name="unified_gui" pkg="rbts_dv_ros_accumulation" type="unified_gui.py" output="screen"
        launch-prefix="bash -c 'sleep 1; exec /usr/bin/python3 $0 $@'">
    <param name="rviz_config" value="$(find flap_roller_viz)/launch/config.rviz"/>
    <param name="logo_dir" value="$(find flap_roller_viz)/../images"/>
    <param name="fullscreen" value="$(arg fullscreen)"/>
    <param name="expected_spacing_mm" value="$(arg expected_spacing_mm)"/>
    <param name="spacing_tolerance_mm" value="$(arg spacing_tolerance_mm)"/>
  </node>

  <!-- Lean tuning bag: raw inputs needed to replay motion compensation and detection. -->
  <group if="$(eval arg('record_bag') and arg('bag_mode') == 'raw' and int(arg('bag_split_size_mb')) &lt;= 0)">
    <node pkg="rosbag" type="record" name="bag_recorder" output="screen"
          launch-prefix="bash -c 'mkdir -p &quot;$(arg bag_output_dir)&quot;; exec &quot;$@&quot;' _"
          args="-o $(arg bag_output_dir)/$(arg bag_prefix)
                /capture_node/events
                /tcp/vel
                /roller/position
                /roller/position_stamped
                /tf
                /tf_static
                /flap/joint_states
                /joint_states"/>
  </group>
  <group if="$(eval arg('record_bag') and arg('bag_mode') == 'raw' and int(arg('bag_split_size_mb')) &gt; 0)">
    <node pkg="rosbag" type="record" name="bag_recorder" output="screen"
          launch-prefix="bash -c 'mkdir -p &quot;$(arg bag_output_dir)&quot;; exec &quot;$@&quot;' _"
          args="--split --size=$(arg bag_split_size_mb)
                -o $(arg bag_output_dir)/$(arg bag_prefix)
                /capture_node/events
                /tcp/vel
                /roller/position
                /roller/position_stamped
                /tf
                /tf_static
                /flap/joint_states
                /joint_states"/>
  </group>

  <!-- Full debug bag: raw inputs plus detector outputs and optional debug images. -->
  <group if="$(eval arg('record_bag') and arg('bag_mode') == 'debug' and int(arg('bag_split_size_mb')) &lt;= 0)">
    <node pkg="rosbag" type="record" name="bag_recorder" output="screen"
          launch-prefix="bash -c 'mkdir -p &quot;$(arg bag_output_dir)&quot;; exec &quot;$@&quot;' _"
          args="-o $(arg bag_output_dir)/$(arg bag_prefix)
                /capture_node/events
                /tcp/vel
                /roller/position
                /roller/position_stamped
                /tf
                /tf_static
                /flap/joint_states
                /joint_states
                /motion_compensator/image
                /motion_compensator/annotated_image
                /hole_events
                /hole_markers
                /hole_detector/debug/preprocessed
                /hole_detector/debug/binary"/>
  </group>
  <group if="$(eval arg('record_bag') and arg('bag_mode') == 'debug' and int(arg('bag_split_size_mb')) &gt; 0)">
    <node pkg="rosbag" type="record" name="bag_recorder" output="screen"
          launch-prefix="bash -c 'mkdir -p &quot;$(arg bag_output_dir)&quot;; exec &quot;$@&quot;' _"
          args="--split --size=$(arg bag_split_size_mb)
                -o $(arg bag_output_dir)/$(arg bag_prefix)
                /capture_node/events
                /tcp/vel
                /roller/position
                /roller/position_stamped
                /tf
                /tf_static
                /flap/joint_states
                /joint_states
                /motion_compensator/image
                /motion_compensator/annotated_image
                /hole_events
                /hole_markers
                /hole_detector/debug/preprocessed
                /hole_detector/debug/binary"/>
  </group>
</launch>
